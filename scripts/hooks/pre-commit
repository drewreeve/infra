#!/usr/bin/env bash

# Git pre-commit hook to ensure secrets.yml files are encrypted
# Place this file at .git/hooks/pre-commit and make it executable

check_encrypted() {
  local file="$1"
  echo "Checking if ${file} is encrypted..."
  if ! grep -q "^\$ANSIBLE_VAULT;" "${file}"; then
    echo "❌ ERROR: ${file} is not encrypted!"
    echo ""
    echo "Please encrypt it with:"
    echo "  ansible-vault encrypt ${file}"
    echo ""
    echo "Or use --no-verify to bypass this check (not recommended)"
    return 1
  else
    echo "✅ ${file} is properly encrypted"
    return 0
  fi
}

failed=0

for secrets_file in $(git diff --cached --name-only | grep "secrets\.yml$"); do
  [[ -f "${secrets_file}" ]] && { check_encrypted "${secrets_file}" || failed=1; }
done

exit ${failed}
